{
  "manifest_version": 3,
  "name": "WatchTogether",
  "version": "1.0.0",
  "description": "Synchronized movie watching with friends across streaming platforms.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.netflix.com/*",
    "https://*.hotstar.com/*",
    "https://*.primevideo.com/*",
    "https://*.disneyplus.com/*",
    "https://*.youtube.com/*",
    "https://*.hulu.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
